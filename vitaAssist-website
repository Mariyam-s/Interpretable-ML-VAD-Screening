    if 'user_id' not in session:
        return redirect('/user-login')
    prediction = None
    if request.method == 'POST':
        try:
            inputs = {
                'age': int(request.form['age']),
                'gender': int(request.form['gender']),
                'bmi': float(request.form['bmi']),
                'veg_intake': int(request.form['veg_intake']),
                'fruit_intake': int(request.form['fruit_intake']),
                'dairy': int(request.form['dairy']),
                'eggs': int(request.form['eggs']),
                'fish_meat': int(request.form['fish_meat']),
                'night_blindness': int(request.form['night_blindness']),
                'eye_dryness': int(request.form['eye_dryness']),
                'recent_infection': int(request.form['recent_infection']),
                'healthcare_access': int(request.form['healthcare_access']),
                'clean_water': int(request.form['clean_water']),
                'sanitation': int(request.form['sanitation']),
            }
        except (ValueError, KeyError):
            return render_template('user_dashboard.html', username=session['username'], error="Please fill all fields correctly.")

        level, label, status, confidence, recs = predict(inputs)

        db = get_db()
        cur = db.cursor()
        cur.execute("""INSERT INTO predictions
            (user_id, age, gender, bmi, veg_intake, fruit_intake, dairy, eggs, fish_meat,
             night_blindness, eye_dryness, recent_infection, healthcare_access, clean_water,
             sanitation, result, deficiency_level)
            VALUES (%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s)""",
            (session['user_id'], inputs['age'], inputs['gender'], inputs['bmi'],
             inputs['veg_intake'], inputs['fruit_intake'], inputs['dairy'], inputs['eggs'],
             inputs['fish_meat'], inputs['night_blindness'], inputs['eye_dryness'],
             inputs['recent_infection'], inputs['healthcare_access'], inputs['clean_water'],
             inputs['sanitation'], label, level))
        db.commit()
        db.close()

        prediction = {**inputs, "level": level, "label": label, "status": status,
                      "confidence": confidence, "recommendations": recs}

    return render_template('user_dashboard.html', username=session['username'], prediction=prediction)


